{
    "version": "7.3",
    "data_api_version": "3.0",
    "routing_model": {
        "DOCTOR_SELECTION": [
            "DATE_TIME_SELECTION"
        ],
        "DATE_TIME_SELECTION": [
            "SUMMARY"
        ],
        "SUMMARY": [
            "PAYMENT"
        ],
        "PAYMENT": []
    },
    "screens": [
        {
            "id": "DOCTOR_SELECTION",
            "title": "Select Specialization",
            "data": {
                "specialties": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "id": {
                                "type": "string"
                            },
                            "title": {
                                "type": "string"
                            }
                        }
                    },
                    "__example__": []
                },
                "doctors": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "id": {
                                "type": "string"
                            },
                            "title": {
                                "type": "string"
                            }
                        }
                    },
                    "__example__": []
                },
                "is_doctor_enabled": {
                    "type": "boolean",
                    "__example__": false
                },
                "patient_name_prefill": {
                    "type": "string",
                    "__example__": ""
                },
                "patient_phone_prefill": {
                    "type": "string",
                    "__example__": ""
                }
            },
            "layout": {
                "type": "SingleColumnLayout",
                "children": [
                    {
                        "type": "Form",
                        "name": "doctor_form",
                        "children": [
                            {
                                "type": "Dropdown",
                                "label": "Medical Specialty",
                                "name": "specialty",
                                "data-source": "${data.specialties}",
                                "required": true,
                                "on-select-action": {
                                    "name": "data_exchange",
                                    "payload": {
                                        "trigger": "specialty_selected",
                                        "specialty": "${form.specialty}"
                                    }
                                }
                            },
                            {
                                "type": "Dropdown",
                                "label": "Available Doctors",
                                "name": "doctor",
                                "data-source": "${data.doctors}",
                                "required": true,
                                "enabled": "${data.is_doctor_enabled}"
                            },
                            {
                                "type": "Footer",
                                "label": "Next",
                                "on-click-action": {
                                    "name": "data_exchange",
                                    "payload": {
                                        "trigger": "doctor_selected_continue",
                                        "specialty": "${form.specialty}",
                                        "doctor": "${form.doctor}"
                                    }
                                }
                            }
                        ]
                    }
                ]
            }
        },
        {
            "id": "DATE_TIME_SELECTION",
            "title": "Date & Time",
            "data": {
                "dates": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "id": {
                                "type": "string"
                            },
                            "title": {
                                "type": "string"
                            }
                        }
                    },
                    "__example__": []
                },
                "times": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "id": {
                                "type": "string"
                            },
                            "title": {
                                "type": "string"
                            }
                        }
                    },
                    "__example__": []
                },
                "is_time_enabled": {
                    "type": "boolean",
                    "__example__": false
                },
                "specialty": {
                    "type": "string",
                    "__example__": ""
                },
                "doctor": {
                    "type": "string",
                    "__example__": ""
                },
                "patient_name_prefill": {
                    "type": "string",
                    "__example__": ""
                },
                "patient_phone_prefill": {
                    "type": "string",
                    "__example__": ""
                }
            },
            "layout": {
                "type": "SingleColumnLayout",
                "children": [
                    {
                        "type": "Form",
                        "name": "datetime_form",
                        "children": [
                            {
                                "type": "Dropdown",
                                "label": "Select Date",
                                "name": "date",
                                "data-source": "${data.dates}",
                                "required": true,
                                "on-select-action": {
                                    "name": "data_exchange",
                                    "payload": {
                                        "trigger": "date_selected",
                                        "specialty": "${data.specialty}",
                                        "doctor": "${data.doctor}",
                                        "date": "${form.date}"
                                    }
                                }
                            },
                            {
                                "type": "Dropdown",
                                "label": "Select Time",
                                "name": "time",
                                "data-source": "${data.times}",
                                "required": true,
                                "enabled": "${data.is_time_enabled}"
                            },
                            {
                                "type": "Footer",
                                "label": "Continue",
                                "on-click-action": {
                                    "name": "data_exchange",
                                    "payload": {
                                        "trigger": "appointment_summary",
                                        "specialty": "${data.specialty}",
                                        "doctor": "${data.doctor}",
                                        "date": "${form.date}",
                                        "time": "${form.time}",
                                        "name": "${data.patient_name_prefill}",
                                        "phone": "${data.patient_phone_prefill}"
                                    }
                                }
                            }
                        ]
                    }
                ]
            }
        },
        {
            "id": "SUMMARY",
            "title": "Confirm Appointment",
            "terminal": false,
            "data": {
                "summary_text": {
                    "type": "string",
                    "__example__": ""
                },
                "specialty": {
                    "type": "string",
                    "__example__": ""
                },
                "doctor": {
                    "type": "string",
                    "__example__": ""
                },
                "date": {
                    "type": "string",
                    "__example__": ""
                },
                "time": {
                    "type": "string",
                    "__example__": ""
                },
                "name": {
                    "type": "string",
                    "__example__": ""
                },
                "phone": {
                    "type": "string",
                    "__example__": ""
                },
                "email": {
                    "type": "string",
                    "__example__": ""
                },
                "symptoms": {
                    "type": "string",
                    "__example__": ""
                }
            },
            "layout": {
                "type": "SingleColumnLayout",
                "children": [
                    {
                        "type": "Form",
                        "name": "summary_form",
                        "children": [
                            {
                                "type": "TextHeading",
                                "text": "Appointment Summary"
                            },
                            {
                                "type": "TextBody",
                                "text": "${data.summary_text}"
                            },
                            {
                                "type": "Footer",
                                "label": "Proceed to Payment",
                                "on-click-action": {
                                    "name": "data_exchange",
                                    "payload": {
                                        "trigger": "proceed_to_payment",
                                        "specialty": "${data.specialty}",
                                        "doctor": "${data.doctor}",
                                        "date": "${data.date}",
                                        "time": "${data.time}",
                                        "name": "${data.name}",
                                        "phone": "${data.phone}",
                                        "email": "${data.email}",
                                        "symptoms": "${data.symptoms}"
                                    }
                                }
                            }
                        ]
                    }
                ]
            }
        },
        {
            "id": "PAYMENT",
            "title": "Select Payment",
            "terminal": true,
            "data": {
                "specialty": {
                    "type": "string",
                    "__example__": ""
                },
                "doctor": {
                    "type": "string",
                    "__example__": ""
                },
                "date": {
                    "type": "string",
                    "__example__": ""
                },
                "time": {
                    "type": "string",
                    "__example__": ""
                },
                "name": {
                    "type": "string",
                    "__example__": ""
                },
                "phone": {
                    "type": "string",
                    "__example__": ""
                },
                "email": {
                    "type": "string",
                    "__example__": ""
                },
                "symptoms": {
                    "type": "string",
                    "__example__": ""
                }
            },
            "layout": {
                "type": "SingleColumnLayout",
                "children": [
                    {
                        "type": "Form",
                        "name": "payment_form",
                        "children": [
                            {
                                "type": "RadioButtonsGroup",
                                "label": "Payment Method",
                                "name": "payment_method",
                                "required": true,
                                "data-source": [
                                    {
                                        "id": "razorpay",
                                        "title": "Razorpay (Online)"
                                    },
                                    {
                                        "id": "cash",
                                        "title": "Cash at Clinic"
                                    }
                                ]
                            },
                            {
                                "type": "Footer",
                                "label": "Confirm Booking",
                                "on-click-action": {
                                    "name": "data_exchange",
                                    "payload": {
                                        "trigger": "final_confirm",
                                        "payment_method": "${form.payment_method}",
                                        "specialty": "${data.specialty}",
                                        "doctor": "${data.doctor}",
                                        "date": "${data.date}",
                                        "time": "${data.time}",
                                        "name": "${data.name}",
                                        "phone": "${data.phone}",
                                        "email": "${data.email}",
                                        "symptoms": "${data.symptoms}"
                                    }
                                }
                            }
                        ]
                    }
                ]
            }
        }
    ]
}